{
  "buildCommand": "pnpm --filter @workspace/furniture-store build",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/furniture-store/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
